{
  "version": 2,
  "name": "learning-platform-server",
  "builds": [
    {
      "src": "server.js",
      "use": "@vercel/node"
    }
  ],
  "rewrites": [
    {
      "source": "/uploads/(.*)",
      "destination": "https://res.cloudinary.com/djwygkmsh/image/upload/v1/$1"
    },
    {
      "source": "/(.*)",
      "destination": "/server.js"
    }
  ]
}

